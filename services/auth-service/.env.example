# Authentication Service — Environment Variables
# Copy this file to .env and fill in real values before starting the service.
# Never commit .env to source control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=900        # seconds — 15 minutes
JWT_REFRESH_EXPIRES_IN=604800    # seconds — 7 days

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── User Service ──────────────────────────────────────────────────────────────
USER_SERVICE_URL=http://localhost:3001
# Must match INTERNAL_API_KEY in user-service .env
INTERNAL_API_KEY=change-me-to-a-shared-secret

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # milliseconds — 15 minutes
RATE_LIMIT_MAX=10             # max login attempts per window per IP
