# User Service — Environment Variables
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to version control.

# Server
PORT=3001
NODE_ENV=development

# MongoDB — dedicated database for this service
MONGODB_URI=mongodb://localhost:27017/user-service-db

# Redis
REDIS_URL=redis://localhost:6379

# JWT — shared secret with Authentication Service (≥ 256-bit random string)
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# bcrypt cost factor (min 12 per constitution security requirements)
BCRYPT_COST=12

# Logging level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Allowed CORS origins (comma-separated, no trailing slash)
# Example: http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000
