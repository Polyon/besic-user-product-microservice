# Product Service — environment variable template
# Copy to .env and fill in values. Never commit .env to version control.

# Server
PORT=3003
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/product-service-db

# JWT — must match the secret used by the Authentication Service
JWT_SECRET=change-me-to-a-256-bit-random-secret

# Redis — used for rate-limiting counters only
REDIS_URL=redis://localhost:6379

# CORS — allowed origin for browser clients
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Logging (debug | info | warn | error | silent)
LOG_LEVEL=info
